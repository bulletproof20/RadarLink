# Doxygen HTML generation for checkpoint and deliverable API reference.
# Run from repository root via compose or: doxygen Doxyfile.checkpoint

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends doxygen \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work

# Compose services invoke doxygen explicitly, e.g.:
#   doxygen Doxyfile.checkpoint
